{
    "name": "@formatica/vue",
    "version": "0.1.0",
    "description": "Schema-driven, fully-typed form builder for Vue 3",
    "type": "module",
    "main": "./dist/formatica.umd.cjs",
    "module": "./dist/formatica.es.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/formatica.es.js",
            "require": "./dist/formatica.umd.cjs",
            "types": "./dist/index.d.ts"
        },
        "./types": {
            "types": "./dist/types/index.d.ts"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "vite build",
        "typecheck": "vue-tsc --noEmit",
        "dev": "vite build --watch"
    },
    "peerDependencies": {
        "vue": "^3.4.0"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.0.0",
        "@vue/test-utils": "^2.4.6",
        "happy-dom": "^20.8.4",
        "vite": "^5.4.0",
        "vitest": "^1.6.0",
        "vue": "^3.4.0",
        "vue-tsc": "^2.0.0"
    },
    "keywords": [
        "vue",
        "vue3",
        "form",
        "form-builder",
        "schema",
        "typescript",
        "tailwind",
        "validation"
    ],
    "license": "MIT",
    "dependencies": {
        "@formatica/core": "workspace:*",
        "libphonenumber-js": "^1.12.40"
    }
}
