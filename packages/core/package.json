{
    "name": "@formatica/core",
    "version": "0.1.0",
    "description": "Framework-agnostic schema-driven form engine — types, validation, parsing, conditions",
    "type": "module",
    "main": "./dist/formatica-core.umd.cjs",
    "module": "./dist/formatica-core.es.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/formatica-core.es.js",
            "require": "./dist/formatica-core.umd.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "vite build && tsc --emitDeclarationOnly --declaration --declarationDir dist",
        "typecheck": "tsc --noEmit",
        "test": "vitest --run"
    },
    "peerDependencies": {
        "libphonenumber-js": "^1.12.0"
    },
    "peerDependenciesMeta": {
        "libphonenumber-js": {
            "optional": true
        }
    },
    "devDependencies": {
        "typescript": "^5.4.0",
        "vite": "^5.4.0",
        "vitest": "^1.6.0"
    },
    "keywords": [
        "form",
        "schema",
        "validation",
        "typescript"
    ],
    "license": "MIT"
}
